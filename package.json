{
  "name": "sentinel",
  "version": "0.1.0",
  "private": true,
  "description": "Sentinel — a security proxy that guards autonomous paying agents on the x402 nanopayment flow.",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:proxy": "pnpm --filter sentinel-proxy dev",
    "dev:mock": "pnpm --filter attack-server dev",
    "dev:agent": "pnpm --filter reference-agent dev",
    "dev:all": "pnpm --parallel --filter sentinel-proxy --filter attack-server dev",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test": "pnpm --filter sentinel-proxy exec node --import tsx --test test/"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  }
}
