# Sentinel public-deployment environment — TEMPLATE (committed WITHOUT real values).
#
# On the EC2 box: copy this to /etc/sentinel.env, fill the SECRET placeholders, then
# `chmod 600 /etc/sentinel.env`. systemd loads it via EnvironmentFile= (see
# deploy/sentinel.service). The REAL /etc/sentinel.env is NEVER committed (D-09,
# threat T-05-16) — only this empty-placeholder template lives in git.
#
# This sets the STRICT public-deployment posture (D-04/D-05): stub settlement so no real
# USDC is ever spent for external traffic, allowInternal=false + a curated allowlist so
# the SSRF guard rejects internal hosts, the per-IP rate limit, the honest-N dev source,
# and the SQLite DB on the persistent EBS volume so traction survives a reboot.

# ── Wallet safety (D-04) ─────────────────────────────────────────────────────
# stub = the Phase 1-3 fake-signed path. External agents NEVER spend the dev's real
# testnet USDC. Flip to `real` ONLY for the controlled recorded demo (Plan 04), never
# on the public box.
SENTINEL_SETTLEMENT_MODE=stub

# ── SSRF posture (D-05) ──────────────────────────────────────────────────────
# Reject any upstream that resolves to loopback/RFC1918/link-local/metadata, even if
# allowlisted. MUST stay false on the public deployment (RESEARCH Pitfall 3).
SENTINEL_ALLOW_INTERNAL=false
# STRICT allowlist: only the demo upstream + curated known x402 endpoints (host:port,
# comma-separated). Add the real demo upstream host before going live. Do NOT wildcard.
SENTINEL_ALLOWLIST=

# ── Per-IP rate limit (D-05) ─────────────────────────────────────────────────
# ~60 req/min/IP keyed on the un-spoofable CF-Connecting-IP; fail-closed 429 over it.
SENTINEL_RATE_LIMIT_MAX=60
SENTINEL_RATE_LIMIT_WINDOW_MS=60000

# ── Honest distinct-agent count (D-07) ───────────────────────────────────────
# The dev's OWN source (CF-Connecting-IP or the X-Sentinel-Agent self-label) to EXCLUDE
# from "N external agents", so the traction figure is honest. Surfaced on the dashboard
# for auditability (RESEARCH Open Q2 RESOLVED). Leave empty to exclude nothing.
SENTINEL_DEV_SOURCE=

# ── Persistent storage (RESEARCH Pitfall 1) ──────────────────────────────────
# The shared SQLite file MUST live on a persistent volume, NOT instance store (which is
# ephemeral — counts would reset on stop/start). On a single-volume box this is just a
# dir on the root EBS volume owned by the service user (e.g. /var/lib/sentinel, mode 750).
# Use a dedicated /mnt/<mount> only if you attach a separate EBS volume.
SENTINEL_DB_PATH=/var/lib/sentinel/sentinel-wallet.db

# ── Listen port (matches the cloudflared ingress target) ─────────────────────
SENTINEL_PORT=8787
SENTINEL_LOG_LEVEL=info

# ── SECRETS — env ONLY, NEVER committed, NEVER logged (D-09, T-04-01) ─────────
# Fill the real values directly in /etc/sentinel.env on the box (chmod 600). Leaving
# the wallet key empty makes `real` mode fall back to stub at call time (fail-closed).
SENTINEL_WALLET_PRIVATE_KEY=
OPENROUTER_API_KEY=

# ── LLM judge (optional on the public box) ───────────────────────────────────
# With no OPENROUTER_API_KEY the seam runs identity passthrough (the deterministic gate
# is still the real enforcement). Set these for the live judged demo.
# SENTINEL_JUDGE_MODEL=google/gemini-2.5-flash
# SENTINEL_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Circle/Arc (only relevant when SENTINEL_SETTLEMENT_MODE=real) ─────────────
# SENTINEL_ARC_CHAIN=arcTestnet   # NEVER "arc" (that is mainnet)
