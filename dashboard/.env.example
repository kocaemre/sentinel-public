# Sentinel dashboard — server-side env (DIST-02, D-03).
#
# SENTINEL_API_BASE_URL is the proxy's stable tunnel URL the dashboard fetches its
# metrics/feed/verdict data from over HTTP (Plan 01 endpoints). It is a PLAIN server
# env var — NOT prefixed NEXT_PUBLIC_ — so the tunnel URL is read only on the server
# (route handlers / server components behind `import "server-only"`) and never ships in
# the client bundle (threat T-05-08 / RESEARCH Pitfall 5).
#
# Set it in the Vercel project Settings -> Environment Variables (not committed):
#   SENTINEL_API_BASE_URL=https://sentinel.<dev-domain>
#
# For local dev against a locally-booted proxy (Plan 01), e.g.:
#   SENTINEL_API_BASE_URL=http://localhost:8787
SENTINEL_API_BASE_URL=
